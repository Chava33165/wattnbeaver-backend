# ========================================
# WattBeaber Project - Git Ignore
# ========================================

# ============ Node.js ============
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ============ Logs ============
logs/
*.log
npm-debug.log*
pids
*.pid
*.seed
*.pid.lock

# ============ Database ============
# Mantener solo la DB principal, ignorar temporales y respaldos antiguos
*.db-shm
*.db-wal
backend/data/backup_*.db
backend/data/*_backup.db
# NO ignorar wattnbeaber.db (la DB principal)

# ============ Environment Variables ============
.env
.env.local
.env.*.local
*.env

# ============ PM2 ============
.pm2/
.pm2-*

# ============ OS Files ============
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============ IDE / Editors ============
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
*~

# ============ Temporary Files ============
*.tmp
*.temp
*.cache
.cache/

# ============ Build / Dist ============
dist/
build/
coverage/

# ============ Cloudflare ============
# Archivo binario de cloudflared
cloudflared

# ============ Respaldos ============
# Ignorar respaldos tar.gz en el directorio principal
*.tar.gz
*.zip
backup_*.txt
verify_backup.sh

# ============ Test Files ============
test-*.js
*.test.js
*.spec.js

# ============ Specific to WattBeaber ============
# Archivos de exploración/debug
explore-*.js
check-*.js
mqtt-client.js
run-simulation-standalone.js

# ============ Keep Important Files ============
# Asegurarse de NO ignorar archivos importantes
!backend/data/wattnbeaber.db
!backend/package.json
!backend/ecosystem.config.js
!.gitignore
!README.md
GITHUB_TOKEN_GUIDE.md
*.db
backend/wattnbeaber.db
